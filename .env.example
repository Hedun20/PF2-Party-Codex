PORT=3050
HOST=0.0.0.0
NODE_ENV=development
TRUST_PROXY=false

# MongoDB is required for the complete identity/campaign workflow. Omit MONGO_URI only
# for legacy vault compatibility and diagnostics; onboarding and Mongo modules return 503.
MONGO_URI=mongodb://<user>:<password>@<hosts>/pf2_party_codex?ssl=true&replicaSet=<replicaSet>&authSource=admin&appName=Cluster0
MONGO_DB_NAME=pf2_party_codex

# Required in production. In local development a fallback exists, but setting this removes the warning.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=dev_secret_change_me_replace_with_long_random_value

# Local/staging inspection mode. Production requires webhook delivery unless the
# explicit ALLOW_OUTBOX_EMAIL_IN_PRODUCTION escape hatch is accepted.
EMAIL_MODE=outbox
EMAIL_FROM="Party Codex <noreply@localhost>"
# EMAIL_MODE=webhook posts a party-codex.email.send JSON event to this endpoint.
# The endpoint must return 2xx; it may return {"id":"provider-message-id"}.
# EMAIL_WEBHOOK_URL=https://mail-gateway.example.com/party-codex
# EMAIL_WEBHOOK_TOKEN=replace_with_a_random_webhook_bearer_token
# EMAIL_WEBHOOK_TIMEOUT_MS=10000

PUBLIC_APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3050

# Platform administration is separate from campaign owner/GM membership. Only
# verified users on this allowlist (or users with a stored platformRoles: ["admin"])
# can access /api/platform/* and detailed identity health.
# PLATFORM_ADMIN_EMAILS=platform-admin@example.com

# No payment flow is simulated. "disabled" exposes free/development entitlements;
# "manual" means plan changes are controlled by an external back office.
BILLING_MODE=disabled

# Operational limits.
API_RATE_LIMIT=600
JSON_BODY_LIMIT=6mb
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=35000
SHUTDOWN_GRACE_MS=10000

# Optional, explicit local/dev owner seed. Never commit real values.
# DEV_OWNER_EMAIL=owner@example.com
# DEV_OWNER_PASSWORD=replace-with-a-unique-12-plus-character-password
# DEV_OWNER_NAME=Local Owner
# DEV_WORKSPACE_NAME=Party Codex Dev Workspace
# DEV_CAMPAIGN_NAME=Party Codex Dev Campaign
# DEV_OWNER_SEED_CONFIRM=CREATE_OR_UPDATE_LOCAL_OWNER
