PORT=3050
HOST=0.0.0.0

# MongoDB is optional during Stage 1. Without MONGO_URI the app runs in legacy
# Markdown/JSON storage mode.
MONGO_URI=mongodb://<user>:<password>@<hosts>/pf2_party_codex?ssl=true&replicaSet=<replicaSet>&authSource=admin&appName=Cluster0
MONGO_DB_NAME=pf2_party_codex
JWT_SECRET=dev_secret_change_me

EMAIL_MODE=outbox
EMAIL_FROM="PF2 Party Codex <noreply@localhost>"
PUBLIC_APP_URL=http://localhost:5173
