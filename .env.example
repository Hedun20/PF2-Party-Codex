PORT=3050
HOST=0.0.0.0

# MongoDB is required for the complete identity/campaign workflow. Omit MONGO_URI only
# for legacy vault compatibility and diagnostics; onboarding and Mongo modules return 503.
MONGO_URI=mongodb://<user>:<password>@<hosts>/pf2_party_codex?ssl=true&replicaSet=<replicaSet>&authSource=admin&appName=Cluster0
MONGO_DB_NAME=pf2_party_codex

# Required in production. In local development a fallback exists, but setting this removes the warning.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=dev_secret_change_me_replace_with_long_random_value

EMAIL_MODE=outbox
# Set this to the sender address you want players to see.
# Example: EMAIL_FROM="Tymur Abbasov <your-email@example.com>"
EMAIL_FROM="Party Codex <noreply@localhost>"
PUBLIC_APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3050

# Optional, explicit local/dev owner seed. Never commit real values.
# DEV_OWNER_EMAIL=owner@example.com
# DEV_OWNER_PASSWORD=replace-with-a-unique-12-plus-character-password
# DEV_OWNER_NAME=Local Owner
# DEV_WORKSPACE_NAME=Party Codex Dev Workspace
# DEV_CAMPAIGN_NAME=Party Codex Dev Campaign
# DEV_OWNER_SEED_CONFIRM=CREATE_OR_UPDATE_LOCAL_OWNER
